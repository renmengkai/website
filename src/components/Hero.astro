---
// Hero Section - 极简科技风格
import projectTypes from '../data/projectTypes.json';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  showCTA?: boolean;
  centered?: boolean;
}

const { 
  title, 
  subtitle,
  description, 
  showCTA = true,
  centered = true 
} = Astro.props;

const heroCards = projectTypes.hero.cards;

const iconMap: Record<string, string> = {
  globe: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  check: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  sparkles: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
  github: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  agent: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  '传播': `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`
};
---

<section class="relative min-h-screen flex items-center">
  <!-- 网格线背景 -->
  <div class="absolute inset-0 bg-grid-fade pointer-events-none" aria-hidden="true"></div>
  
  <div class={`container-custom relative ${centered ? 'text-center' : ''}`}>
    <div class={`${centered ? 'max-w-4xl mx-auto' : 'max-w-3xl'} py-8`}>
      <!-- 主标题 -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6 text-gray-900
                 animate-fade-in-up opacity-0" 
          style="animation-delay: 100ms; animation-fill-mode: forwards;">
        {title}
      </h1>
      
      <!-- 描述 - 极简标签风格 -->
      {description && (
        <div class="animate-fade-in-up opacity-0"
             style="animation-delay: 200ms; animation-fill-mode: forwards;">
          <div class="flex flex-wrap justify-center gap-3 mb-8">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-600">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              AI Agent 工具开发
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-600">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              多智能体编排
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-600">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
              80% 工作由 AI 完成
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-600">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              降本增效
            </span>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm text-gray-600">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              招商合作共赢
            </span>
          </div>
        </div>
      )}
      
      <!-- CTA 按钮 -->
      {showCTA && (
        <div class="flex flex-wrap items-center justify-center gap-4
                    animate-fade-in-up opacity-0"
             style="animation-delay: 300ms; animation-fill-mode: forwards;">
          <a href="/projects" class="inline-flex items-center gap-2 bg-dark-100 text-white px-7 py-3.5 rounded-full text-base font-medium hover:bg-dark-300 transition-all">
            查看作品
            <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="inline-flex items-center gap-2 bg-white text-gray-900 px-7 py-3.5 rounded-full text-base font-medium border border-gray-200 hover:bg-gray-50 hover:border-gray-300 transition-all">
            了解更多
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      )}
    </div>
    
    <!-- 底部统计卡片区域 -->
    <div class="hidden lg:block mt-24">
      <div class="flex justify-center gap-6">
        {heroCards.map((card: any, i: number) => {
          const iconSvg = iconMap[card.icon || 'globe'];
          
          if (card.type === 'stats') {
            return (
              <div class="bg-white rounded-2xl p-5 border border-gray-200 w-[280px] h-[168px] flex flex-col text-left animate-fade-in-up opacity-0 transition-all duration-300 hover:border-gray-300"
                   style={`animation-delay: ${400 + i * 100}ms; animation-fill-mode: forwards;`}>
                <!-- 第一行：图标 + 趋势标签 -->
                <div class="flex items-center justify-between h-9">
                  <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center text-gray-600">
                    <Fragment set:html={iconSvg} />
                  </div>
                  <span class="text-xs text-primary-500 flex items-center gap-0.5 font-medium bg-primary-500/10 px-2 py-1 rounded-full">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={card.trendType === 'up' ? "M12 19V5m-7 7l7-7 7 7" : "M12 5v14m-7-7l7 7 7-7"} />
                    </svg>
                    {card.trend}
                  </span>
                </div>
                <!-- 第二行：标签 -->
                <div class="h-6 flex items-center mt-4">
                  <span class="text-sm text-gray-500">{card.label}</span>
                </div>
                <!-- 第三行：数值 + 描述 -->
                <div class="h-12 flex items-center mt-2">
                  <span class="text-3xl font-bold text-gray-900 mr-2">{card.value}</span>
                  <span class="text-xs text-gray-400 pt-1.5">{card.description}</span>
                </div>
              </div>
            );
          }
          if (card.type === 'default') {
            return (
              <div class="bg-white rounded-2xl p-5 border border-gray-200 w-[280px] h-[168px] flex flex-col text-left animate-fade-in-up opacity-0 transition-all duration-300 hover:border-gray-300"
                   style={`animation-delay: ${400 + i * 100}ms; animation-fill-mode: forwards;`}>
                <!-- 第一行：图标 -->
                <div class="flex items-center justify-between h-9">
                  <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center text-gray-600">
                    <Fragment set:html={iconSvg} />
                  </div>
                </div>
                <!-- 第二行：标签 -->
                <div class="h-6 flex items-center mt-4">
                  <span class="text-sm text-gray-500">{card.label}</span>
                </div>
                <!-- 第三行：描述 -->
                <div class="h-12 flex items-center mt-2">
                  <span class="text-xs text-gray-400">{card.description}</span>
                </div>
              </div>
            );
          }
          if (card.type === 'tags') {
            return (
              <div class="bg-white rounded-2xl p-5 border border-gray-200 w-[280px] h-[168px] flex flex-col text-left animate-fade-in-up opacity-0 transition-all duration-300 hover:border-gray-300"
                   style={`animation-delay: ${400 + i * 100}ms; animation-fill-mode: forwards;`}>
                <!-- 第一行：图标 + 更多图标 -->
                <div class="flex items-center justify-between h-9">
                  <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center text-gray-600">
                    <Fragment set:html={iconSvg} />
                  </div>
                  <svg class="w-4 h-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                  </svg>
                </div>
                <!-- 第二行：标签 -->
                <div class="h-6 flex items-center mt-4">
                  <span class="text-sm font-medium text-gray-900">{card.label}</span>
                </div>
                <!-- 第三行：Tags -->
                <div class="h-12 flex items-center mt-2">
                  <div class="flex gap-2 flex-nowrap overflow-hidden">
                    {card.tags.map((tag: { label: string; active: boolean }) => (
                      <span class={`px-3 py-1.5 rounded-full text-xs font-medium shrink-0 ${tag.active ? 'bg-primary-500/10 text-primary-600 ring-1 ring-primary-500/20' : 'bg-gray-100 text-gray-500'}`}>
                        {tag.label}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            );
          }
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .bg-grid-fade {
    background-image: 
      linear-gradient(to right, rgba(0,0,0,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }
</style>