---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';

// 关于页面数据
const about = {
  name: '任孟锴',
  title: '创始人 & CEO',
  quote: 'AI时代已经到来，我们致力于用AI Agent技术帮助企业降本增效。在我们团队中，80%的工作由AI Agent完成，这让我们能够以更高的效率、更低的成本为客户创造价值。我们相信，选择我们，将是您在未来10年内做出的最好决策。',
};

// 核心价值观
const values = [
  {
    icon: 'innovation',
    title: 'AI驱动',
    description: '80%工作由AI Agent完成，以最高效率交付卓越成果。'
  },
  {
    icon: 'integrity',
    title: '合作共赢',
    description: '招商合作，与合作伙伴共同成长，在AI时代携手领先。'
  },
  {
    icon: 'customer',
    title: '降本增效',
    description: '帮助企业适应时代变化，实现数字化转型与效率提升。'
  }
];

// 统计数据
const stats = [
  { value: '80%', label: '工作由AI Agent完成' },
  { value: '10年', label: '未来领先的选择' },
  { value: '24*7', label: '全天候AI协作' }
];

// 技术栈
const techStack = [
  {
    name: 'Web 开发',
    icon: 'web',
    languages: ['TypeScript', 'JavaScript', 'Go', 'Rust'],
    frameworks: ['Vue/Nuxt', 'Node.js', 'Astro'],
    percent: 45
  },
  {
    name: '跨端应用',
    icon: 'mobile',
    languages: ['TypeScript', 'JavaScript', 'Python'],
    frameworks: ['微信小程序', 'React Native', 'Tauri'],
    percent: 30
  },
  {
    name: '工具与 CLI',
    icon: 'cli',
    languages: ['Rust', 'Go', 'Python', 'TypeScript'],
    frameworks: ['Clap', 'Cobra', 'Raycast'],
    percent: 25
  }
];

// FAQ 数据
const faqs = [
  {
    question: '你们擅长哪些技术？',
    answer: '我们精通多种编程语言：Python、JavaScript、Java、Go、Rust，以及前端框架Vue、React、Tauri、Electron等。我们在AI Agent开发和多智能体编排方面具有深厚的专业知识。'
  },
  {
    question: 'AI Agent能完成哪些工作？',
    answer: '在我们团队中，80%的工作由AI Agent完成，包括代码编写、测试、文档生成、数据分析、自动化流程等。这让我们的开发效率大幅提升，同时降低成本。'
  },
  {
    question: '你们提供哪些服务？',
    answer: '我们专注于开发AI Agent工具和Agent Team编排工具，帮助企业构建智能化的工作流程，实现降本增效。我们提供从咨询到实施的完整解决方案。'
  },
  {
    question: '如何与你们合作？',
    answer: '我们目前处于创业阶段，诚挚邀请招商合作。无论您是希望采用AI技术的企业，还是寻求合作的伙伴，我们都欢迎与您洽谈，共同在AI时代领先发展。'
  }
];
---

<Layout 
  title="关于 - RMK"
  description="了解更多关于我们的背景、价值观和团队"
>
  <!-- Hero 区域 -->
  <section class="pt-32 pb-16">
    <div class="container-custom">
      <div class="text-center mb-4">
        <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">关于我们</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 text-center max-w-4xl mx-auto mb-6">
        AI时代的创新团队
      </h1>
      <p class="text-md text-gray-500 text-center max-w-2xl mx-auto">
        专注AI Agent工具与多智能体编排，助力企业降本增效，共赢AI时代。
      </p>
    </div>
  </section>

  <!-- CEO 引言区域 -->
  <section class="py-16">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- 左侧图片 -->
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-2xl overflow-hidden">
            <img 
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=400&fit=crop" 
              alt="团队协作"
              class="w-full h-64 object-cover"
            />
          </div>
          <div class="rounded-2xl overflow-hidden mt-8">
            <img 
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&h=400&fit=crop" 
              alt="办公工作"
              class="w-full h-64 object-cover"
            />
          </div>
        </div>
        
        <!-- 右侧引言 -->
        <div class="relative">
          <!-- 引号装饰 -->
          <div class="absolute -top-4 -left-4 text-8xl text-gray-100 font-serif leading-none">"</div>
          
          <div class="relative z-10">
            <!-- CEO 信息 -->
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-full overflow-hidden">
                <img 
                  src="/images/founder.jpg" 
                  alt={about.name}
                  class="w-full h-full object-cover object-top scale-125"
                  style="transform: rotate(-10deg) scale(1.25)"
                />
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{about.name}</h3>
                <p class="text-sm text-gray-500">{about.title}</p>
              </div>
            </div>
            
            <!-- 引言内容 -->
            <p class="text-lg text-gray-600 leading-relaxed">
              {about.quote}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 客户 Logo -->
  <section class="py-20 border-y border-gray-100">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">团队实力</span>
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mt-3">我们的团队来自</h2>
          <p class="text-lg text-gray-500 mt-4">核心成员均来自一线互联网公司，拥有丰富的技术经验与行业资源</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center hover:border-gray-200 transition-colors">
            <div class="text-4xl font-bold text-gray-900">美团</div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center hover:border-gray-200 transition-colors">
            <div class="text-4xl font-bold text-gray-900">京东</div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center hover:border-gray-200 transition-colors">
            <div class="text-4xl font-bold text-gray-900">小米</div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center hover:border-gray-200 transition-colors">
            <div class="text-4xl font-bold text-gray-900">华为</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 核心价值观 -->
  <section class="py-20">
    <div class="container-custom">
      <div class="text-center mb-12">
        <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">核心价值观</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mt-3">我们的优势</h2>
        <p class="text-lg text-gray-500 mt-4 max-w-2xl mx-auto">
          AI驱动开发，高效交付，助力企业在AI时代领先发展。
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map((value) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gray-100 flex items-center justify-center">
              {value.icon === 'innovation' && (
                <svg class="w-8 h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              )}
              {value.icon === 'integrity' && (
                <svg class="w-8 h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {value.icon === 'customer' && (
                <svg class="w-8 h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{value.title}</h3>
            <p class="text-gray-500">{value.description}</p>
          </div>
        ))}
      </div>
      
      <!-- 统计数字 -->
      <div class="grid grid-cols-3 gap-8 mt-16 pt-16 border-t border-gray-100">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl lg:text-5xl font-bold text-gray-900 mb-2">{stat.value}</div>
            <p class="text-gray-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 技术栈展示 -->
  <section class="py-20 border-t border-gray-100">
    <div class="container-custom">
      <div class="text-center mb-12">
        <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">技术能力</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mt-3">技术栈</h2>
        <p class="text-lg text-gray-500 mt-4">多语言、多框架的技术储备</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {techStack.map((group) => (
          <div class="rounded-2xl border border-gray-100 overflow-hidden">
            <!-- 分组标题 -->
            <div class="flex items-center justify-between px-5 py-4 bg-gray-50 border-b border-gray-100">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-dark-100 flex items-center justify-center">
                  {group.icon === 'web' && (
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                  )}
                  {group.icon === 'mobile' && (
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  )}
                  {group.icon === 'cli' && (
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  )}
                </div>
                <span class="text-sm font-semibold text-gray-900">{group.name}</span>
              </div>
              <span class="text-xs font-medium px-2 py-1 rounded-full bg-gray-100 text-gray-600">{group.percent}%</span>
            </div>
            <!-- 语言列表 -->
            <div class="px-5 py-3 bg-white border-b border-gray-100">
              <div class="flex flex-wrap gap-1">
                {group.languages.map((lang) => (
                  <span class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-600">{lang}</span>
                ))}
              </div>
            </div>
            <!-- 框架列表 -->
            <div class="px-5 py-4 bg-white">
              <div class="flex flex-wrap gap-2">
                {group.frameworks.map((fw) => (
                  <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                    <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {fw}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 业务方向 -->
  <section class="py-20 border-t border-gray-100">
    <div class="container-custom">
      <div class="text-center mb-12">
        <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">业务布局</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mt-3">业务方向</h2>
        <p class="text-lg text-gray-500 mt-4">AI Agent工具开发与多智能体编排</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">AI Agent 开发</h3>
          <p class="text-sm text-gray-500">开发智能、高效的AI Agent工具，自动化处理各类业务场景</p>
        </div>
        
        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Agent Team 编排</h3>
          <p class="text-sm text-gray-500">多智能体协同编排，构建复杂的AI工作流</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">企业数字化咨询</h3>
          <p class="text-sm text-gray-500">帮助企业规划AI转型路径，实现降本增效</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ 区域 -->
  <section class="py-20 bg-gray-50/50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <span class="text-sm font-medium text-gray-400 uppercase tracking-wider">常见问题</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mt-3">常见问答</h2>
        <p class="text-lg text-gray-500 mt-4 max-w-2xl mx-auto">
          了解我们的服务与合作方式
        </p>
      </div>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq, index) => (
          <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden faq-item">
            <button 
              class="w-full px-6 py-5 text-left flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors faq-trigger"
              data-index={index}
            >
              <span class="font-medium text-gray-900">{index + 1}. {faq.question}</span>
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 faq-icon transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-gray-500">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA 区域 -->
  <section class="py-20">
    <div class="container-custom">
      <div class="bg-dark-100 rounded-3xl p-12 lg:p-16 text-center">
        <div class="relative z-10">
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
            招商合作，共赢AI时代
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8">
            我们正处于创业阶段，诚挚邀请合作伙伴。企业降本增效，适用时代变化的任务交给我们，会是未来10年内最好的选择。
          </p>
          <Button href="/contact" variant="primary" showArrow class="bg-primary-500 text-gray-900 font-semibold hover:bg-primary-400">
            联系我们
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // FAQ 手风琴交互
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = item?.querySelector('.faq-icon');
      
      // 关闭其他打开的项
      document.querySelectorAll('.faq-item').forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.querySelector('.faq-content')?.classList.add('hidden');
          otherItem.querySelector('.faq-icon')?.classList.remove('rotate-180');
        }
      });
      
      // 切换当前项
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
