---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';

const phoneNumber = import.meta.env.PUBLIC_PHONE_NUMBER || 'NOT_SET';

const contactInfo = [
  {
    icon: 'email',
    title: '邮箱',
    value: 'renmengkai@gmail.com',
    link: 'mailto:renmengkai@gmail.com'
  },
  {
    icon: 'phone',
    title: '电话',
    value: phoneNumber,
    link: `tel:${(phoneNumber || '').replace(/\s/g, '')}`
  },
  {
    icon: 'location',
    title: '地址',
    value: '河北省石家庄市长安区谈固大街',
    link: null
  }
];

const socials = [
  { name: 'GitHub', icon: 'github', url: 'https://github.com/renmengkai' },
];

const workHours = [
  { day: '周一至周五', hours: '9:00 - 18:00' },
  { day: '周六', hours: '10:00 - 16:00' },
  { day: '周日', hours: '休息' }
];
---

<Layout 
  title="联系我们 - RMK"
  description="与我们取得联系，讨论项目合作或技术咨询"
>
  <section class="pt-32 pb-16 lg:pb-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="container-custom relative z-10">
      <div class="text-center mb-6 animate-fade-in-up">
        <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-600 text-sm font-medium rounded-full uppercase tracking-wider">联系我们</span>
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-gray-900 text-center max-w-4xl mx-auto mb-8 animate-fade-in-up animation-delay-100">
        开始对话
      </h1>
      <p class="text-xl sm:text-2xl text-gray-500 text-center max-w-2xl mx-auto animate-fade-in-up animation-delay-200">
        无论是项目咨询、技术探讨还是简单的交流，我们都期待收到您的消息。
      </p>
      
      <!-- 快速联系方式 -->
      <div class="flex flex-wrap justify-center gap-4 mt-10 animate-fade-in-up animation-delay-300">
        <a href="mailto:renmengkai@gmail.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white border border-gray-200 text-gray-700 hover:border-gray-300 hover:bg-gray-50 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-sm font-medium">发送邮件</span>
        </a>
        <a href={`tel:${(phoneNumber || '').replace(/\s/g, '')}`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white border border-gray-200 text-gray-700 hover:border-gray-300 hover:bg-gray-50 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="text-sm font-medium">电话联系</span>
        </a>
      </div>
    </div>
  </section>

  <section class="pb-16 lg:pb-24">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">

        <div class="flex flex-col gap-6">
          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:border-gray-300 transition-colors duration-300 flex-1">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-bold text-gray-900">发送消息</h2>
              </div>
            </div>
            <p class="text-gray-500 mb-8">填写以下表单，我们会尽快回复您。</p>
            
            <div id="form-status" class="hidden mb-6 p-4 rounded-xl"></div>
            
            <form id="contact-form" class="space-y-6 flex-1 flex flex-col">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="name" class="block text-sm font-medium text-gray-700">姓名 <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                      <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                    </div>
                    <input 
                      type="text" 
                      id="name" 
                      name="name"
                      placeholder="您的姓名"
                      class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white text-gray-900 placeholder-gray-400"
                    />
                  </div>
                  <p id="name-error" class="mt-1 text-sm text-red-500 hidden"></p>
                </div>
                <div class="space-y-2">
                  <label for="email" class="block text-sm font-medium text-gray-700">邮箱 <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                      <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <input 
                      type="email" 
                      id="email" 
                      name="email"
                      placeholder="your@email.com"
                      class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white text-gray-900 placeholder-gray-400"
                    />
                  </div>
                  <p id="email-error" class="mt-1 text-sm text-red-500 hidden"></p>
                </div>
              </div>
              
              <div class="space-y-2">
                <label for="subject" class="block text-sm font-medium text-gray-700">主题 <span class="text-red-500">*</span></label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                  </div>
                  <select 
                    id="subject" 
                    name="subject"
                    class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all bg-white text-gray-900 appearance-none cursor-pointer"
                  >
                    <option value="">请选择咨询类型</option>
                    <option value="project">项目合作</option>
                    <option value="tech">技术咨询</option>
                    <option value="feedback">反馈建议</option>
                    <option value="other">其他</option>
                  </select>
                  <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
                <p id="subject-error" class="mt-1 text-sm text-red-500 hidden"></p>
              </div>
              
              <div class="space-y-2">
                <label for="message" class="block text-sm font-medium text-gray-700">消息内容 <span class="text-red-500">*</span></label>
                <div class="relative">
                  <div class="absolute top-4 left-4 pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </div>
                  <textarea 
                    id="message" 
                    name="message"
                    rows="5"
                    placeholder="请详细描述您的需求或问题..."
                    class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all resize-none bg-white text-gray-900 placeholder-gray-400"
                  ></textarea>
                </div>
                <p id="message-error" class="mt-1 text-sm text-red-500 hidden"></p>
                <div class="flex justify-between items-center">
                  <p class="text-xs text-gray-400">最少10个字符，最多2000个字符</p>
                  <p id="char-count" class="text-xs text-gray-400">0/2000</p>
                </div>
              </div>
              
              <div class="pt-2 mt-auto">
                <button 
                  type="submit" 
                  id="submit-btn"
                  class="inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 bg-dark-100 text-white hover:bg-dark-300 px-8 py-4 rounded-full w-full sm:w-auto group"
                >
                  <span id="btn-text">发送消息</span>
                  <svg id="btn-arrow" class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                  <svg id="btn-loading" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <!-- 服务承诺卡片 -->
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 hover:border-gray-300 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-5">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center flex-shrink-0 border border-gray-200">
                <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">我们的承诺</h3>
                <p class="text-gray-500 text-sm">
                  我们承诺在24小时内回复您的消息，并为您提供最优质的服务。
                </p>
              </div>
            </div>
            
            <!-- 服务特点 -->
            <div class="space-y-3 mb-5">
              <div class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200">
                <div class="w-8 h-8 rounded-lg bg-primary-500/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">快速响应</p>
                  <p class="text-xs text-gray-500">24小时内回复，紧急情况优先处理</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200">
                <div class="w-8 h-8 rounded-lg bg-primary-500/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">质量保障</p>
                  <p class="text-xs text-gray-500">AI驱动开发，80%工作由智能体完成</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200">
                <div class="w-8 h-8 rounded-lg bg-primary-500/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">专属服务</p>
                  <p class="text-xs text-gray-500">一对一项目经理全程跟进</p>
                </div>
              </div>
            </div>
            
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-500/10 text-primary-600 ring-1 ring-primary-500/20">
                快速响应
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-500/10 text-primary-600 ring-1 ring-primary-500/20">
                专业服务
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-500/10 text-primary-600 ring-1 ring-primary-500/20">
                AI驱动
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-6">
          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:border-gray-300 transition-colors duration-300 flex-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900">联系方式</h3>
            </div>
            <div class="space-y-4">
              {contactInfo.map((info) => (
                <a href={info.link || '#'} class="flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 transition-all duration-200 group">
                  <div class="w-10 h-10 rounded-xl bg-gray-100 group-hover:bg-primary-500/10 flex items-center justify-center flex-shrink-0 transition-colors duration-200">
                    {info.icon === 'email' && (
                      <svg class="w-5 h-5 text-gray-600 group-hover:text-primary-600 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    )}
                    {info.icon === 'phone' && (
                      <svg class="w-5 h-5 text-gray-600 group-hover:text-primary-600 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                    )}
                    {info.icon === 'location' && (
                      <svg class="w-5 h-5 text-gray-600 group-hover:text-primary-600 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    )}
                  </div>
                  <div class="flex-1">
                    <p class="text-sm text-gray-500 mb-0.5">{info.title}</p>
                    {info.link ? (
                      <p class="text-gray-900 font-medium group-hover:text-primary-600 transition-colors duration-200">
                        {info.value}
                      </p>
                    ) : (
                      <p class="text-gray-900 font-medium">{info.value}</p>
                    )}
                  </div>
                  {info.link && (
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-500 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  )}
                </a>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:border-gray-300 transition-colors duration-300 flex-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900">工作时间</h3>
            </div>
            <div class="space-y-4">
              {workHours.map((item, index) => (
                <div class={`flex justify-between items-center py-3 ${index < workHours.length - 1 ? 'border-b border-gray-100' : ''}`}>
                  <span class="text-gray-600 font-medium">{item.day}</span>
                  <span class={`font-medium ${item.hours === '休息' ? 'text-gray-400 bg-gray-100 px-3 py-1 rounded-full text-sm' : 'text-gray-900'}`}>{item.hours}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-8 hover:border-gray-300 transition-colors duration-300 flex-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900">关注我们</h3>
            </div>
            <div class="flex flex-wrap gap-3">
              {socials.map((social) => (
                <a 
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-gray-100 text-gray-600 hover:bg-primary-500/10 hover:text-primary-600 transition-all duration-200 group"
                >
                  {social.icon === 'github' && (
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  )}
                  <span class="text-sm font-medium">{social.name}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 hover:border-gray-300 transition-colors duration-300 flex-1">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center flex-shrink-0 border border-gray-200">
                <svg class="w-6 h-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">有疑问？</h3>
                <p class="text-gray-500 text-sm mb-4">
                  在发送消息之前，您可以先查看常见问题解答。
                </p>
                <Button href="/about#faq" variant="secondary" size="sm">
                  查看常见问题
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 lg:pb-24">
    <div class="container-custom">
      <div class="bg-dark-100 rounded-3xl p-12 lg:p-16 text-center relative overflow-hidden">
        <!-- 装饰元素 -->
        <div class="absolute top-0 left-0 w-full h-full opacity-10">
          <div class="absolute top-10 left-10 w-20 h-20 rounded-full border border-white/20"></div>
          <div class="absolute bottom-10 right-10 w-32 h-32 rounded-full border border-white/20"></div>
          <div class="absolute top-1/2 left-1/4 w-16 h-16 rounded-full border border-white/20"></div>
        </div>
        
        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-white/80 text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            快速响应
          </div>
          
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
            期待与您的合作
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8 text-lg">
            我们始终致力于为客户提供最优质的服务和解决方案，让我们一起创造卓越。
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/projects" class="inline-flex items-center gap-2 bg-primary-500 text-gray-900 font-semibold px-8 py-4 rounded-full text-base hover:bg-primary-400 transition-colors duration-200 group">
              查看作品
              <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/about" class="inline-flex items-center gap-2 text-white hover:text-primary-500 px-6 py-4 transition-colors duration-200 font-medium">
              了解更多
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
          
          <!-- 统计信息 -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-12 pt-8 border-t border-white/10">
            <div>
              <div class="text-3xl font-bold text-white mb-1">24h</div>
              <div class="text-gray-400 text-sm">平均响应时间</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">100%</div>
              <div class="text-gray-400 text-sm">客户满意度</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white mb-1">80%</div>
              <div class="text-gray-400 text-sm">AI驱动效率</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnArrow = document.getElementById('btn-arrow') as HTMLElement;
  const btnLoading = document.getElementById('btn-loading') as HTMLElement;

  const nameInput = document.getElementById('name') as HTMLInputElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const subjectSelect = document.getElementById('subject') as HTMLSelectElement;
  const messageTextarea = document.getElementById('message') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count') as HTMLParagraphElement;

  const nameError = document.getElementById('name-error') as HTMLParagraphElement;
  const emailError = document.getElementById('email-error') as HTMLParagraphElement;
  const subjectError = document.getElementById('subject-error') as HTMLParagraphElement;
  const messageError = document.getElementById('message-error') as HTMLParagraphElement;

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  // 字符计数器
  function updateCharCount() {
    const count = messageTextarea.value.length;
    charCount.textContent = `${count}/2000`;
    
    if (count > 2000) {
      charCount.classList.add('text-red-500');
      charCount.classList.remove('text-gray-400');
    } else if (count > 1800) {
      charCount.classList.add('text-yellow-500');
      charCount.classList.remove('text-gray-400', 'text-red-500');
    } else {
      charCount.classList.add('text-gray-400');
      charCount.classList.remove('text-red-500', 'text-yellow-500');
    }
  }

  messageTextarea.addEventListener('input', updateCharCount);

  function clearErrors() {
    [nameError, emailError, subjectError, messageError].forEach(el => {
      el.textContent = '';
      el.classList.add('hidden');
    });
    [nameInput, emailInput, subjectSelect, messageTextarea].forEach(el => {
      el.classList.remove('border-red-500');
    });
  }

  function showError(element: HTMLElement, errorEl: HTMLParagraphElement, message: string) {
    element.classList.add('border-red-500');
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  function validateForm(): boolean {
    clearErrors();
    let isValid = true;

    const name = nameInput.value.trim();
    if (!name) {
      showError(nameInput, nameError, '请输入您的姓名');
      isValid = false;
    } else if (name.length < 2) {
      showError(nameInput, nameError, '姓名至少需要2个字符');
      isValid = false;
    } else if (name.length > 50) {
      showError(nameInput, nameError, '姓名不能超过50个字符');
      isValid = false;
    }

    const email = emailInput.value.trim();
    if (!email) {
      showError(emailInput, emailError, '请输入您的邮箱');
      isValid = false;
    } else if (!emailRegex.test(email)) {
      showError(emailInput, emailError, '请输入有效的邮箱地址');
      isValid = false;
    }

    const subject = subjectSelect.value;
    if (!subject) {
      showError(subjectSelect, subjectError, '请选择咨询类型');
      isValid = false;
    }

    const message = messageTextarea.value.trim();
    if (!message) {
      showError(messageTextarea, messageError, '请输入消息内容');
      isValid = false;
    } else if (message.length < 10) {
      showError(messageTextarea, messageError, '消息内容至少需要10个字符');
      isValid = false;
    } else if (message.length > 2000) {
      showError(messageTextarea, messageError, '消息内容不能超过2000个字符');
      isValid = false;
    }

    return isValid;
  }

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    if (loading) {
      btnText.textContent = '发送中...';
      btnArrow.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    } else {
      btnText.textContent = '发送消息';
      btnArrow.classList.remove('hidden');
      btnLoading.classList.add('hidden');
      submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
    }
  }

  function showStatus(success: boolean, message: string) {
    statusDiv.classList.remove('hidden', 'bg-green-50', 'text-green-700', 'bg-red-50', 'text-red-700', 'border', 'border-green-200', 'border-red-200');
    if (success) {
      statusDiv.classList.add('bg-green-50', 'text-green-700', 'border', 'border-green-200');
    } else {
      statusDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
    }
    statusDiv.textContent = message;
    statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validateForm()) {
      return;
    }

    setLoading(true);
    statusDiv.classList.add('hidden');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name: nameInput.value.trim(),
          email: emailInput.value.trim(),
          subject: subjectSelect.value,
          message: messageTextarea.value.trim(),
        }),
      });

      const result = await response.json();

      if (result.success) {
        showStatus(true, result.message || '消息发送成功，我们会尽快回复您！');
        form.reset();
        clearErrors();
        updateCharCount(); // 重置字符计数
      } else {
        if (result.errors) {
          clearErrors();
          if (result.errors.name) showError(nameInput, nameError, result.errors.name);
          if (result.errors.email) showError(emailInput, emailError, result.errors.email);
          if (result.errors.subject) showError(subjectSelect, subjectError, result.errors.subject);
          if (result.errors.message) showError(messageTextarea, messageError, result.errors.message);
        }
        showStatus(false, result.message || '发送失败，请检查表单内容');
      }
    } catch (error) {
      console.error('Submit error:', error);
      showStatus(false, '网络错误，请稍后重试');
    } finally {
      setLoading(false);
    }
  });

  [nameInput, emailInput, messageTextarea].forEach(input => {
    input.addEventListener('input', () => {
      const errorEl = document.getElementById(`${input.id}-error`) as HTMLParagraphElement;
      input.classList.remove('border-red-500');
      errorEl.classList.add('hidden');
    });
  });

  subjectSelect.addEventListener('change', () => {
    subjectSelect.classList.remove('border-red-500');
    subjectError.classList.add('hidden');
  });

  // 输入框焦点效果
  const inputs = [nameInput, emailInput, subjectSelect, messageTextarea];
  inputs.forEach(input => {
    input.addEventListener('focus', () => {
      const parent = input.closest('.relative');
      if (parent) {
        const icon = parent.querySelector('svg');
        if (icon) {
          icon.classList.add('text-primary-500');
          icon.classList.remove('text-gray-400');
        }
      }
    });
    
    input.addEventListener('blur', () => {
      const parent = input.closest('.relative');
      if (parent) {
        const icon = parent.querySelector('svg');
        if (icon) {
          icon.classList.remove('text-primary-500');
          icon.classList.add('text-gray-400');
        }
      }
    });
  });
</script>