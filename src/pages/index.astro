---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import DashboardTabs from '../components/DashboardTabs.vue';
import { fetchSanity } from '../lib/sanity';

// 从 Sanity 获取最新文章（3篇）
const postsQuery = `*[_type == "post"] | order(publishedAt desc)[0...3] {
  _id,
  title,
  slug,
  excerpt,
  publishedAt,
  "coverImage": coverImage.asset->url,
  categories[]->{title, slug}
}`;

// 从 Sanity 获取项目（优先精选，否则显示所有项目）
const projectsQuery = `*[_type == "project"] | order(featured desc, order asc)[0...3] {
  _id,
  title,
  slug,
  description,
  "thumbnail": thumbnail.asset->url,
  technologies,
  featured
}`;

// 并行获取数据
const [posts, projects] = await Promise.all([
  fetchSanity<any[]>(postsQuery),
  fetchSanity<any[]>(projectsQuery)
]);
---

<Layout title="RMK - 博客与作品集">
  <!-- Hero Section -->
  <Hero 
    title="AI Agent 驱动的开发团队"
    description="专注 AI Agent 工具与多智能体编排，80%工作由AI完成。助力企业降本增效，招商合作共赢AI时代。"
  />

  <!-- 数据统计展示 -->
  <section class="py-16 border-t border-gray-100">
    <div class="container-custom">
      <DashboardTabs client:visible />
    </div>
  </section>

  <!-- 最新日志 -->
  <section class="section">
    <div class="container-custom">
      <SectionTitle 
        title="最新日志" 
        subtitle="博客"
      >
        记录技术探索与思考，分享学习心得与实践经验
      </SectionTitle>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {posts.map((post) => (
          <PostCard
            title={post.title}
            excerpt={post.excerpt}
            slug={post.slug}
            coverImage={post.coverImage}
            publishedAt={post.publishedAt}
            categories={post.categories}
          />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <Button href="/blog" variant="secondary" showArrow>
          查看全部日志
        </Button>
      </div>
    </div>
  </section>

  <!-- 精选作品 -->
  <section class="section bg-gray-50/50">
    <div class="container-custom">
      <SectionTitle 
        title="精选作品" 
        subtitle="项目"
      >
        展示我参与或独立完成的项目，从创意到落地的完整历程
      </SectionTitle>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            slug={project.slug}
            thumbnail={project.thumbnail}
            technologies={project.technologies}
            featured={project.featured}
          />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <Button href="/projects" variant="secondary" showArrow>
          查看全部作品
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section">
    <div class="container-custom">
      <div class="bg-white rounded-3xl border border-gray-100 shadow-card text-center py-16 lg:py-20 px-6">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          有项目想法？让我们聊聊
        </h2>
        <p class="text-lg text-gray-500 max-w-xl mx-auto mb-8">
          无论是技术咨询、项目合作还是单纯的交流，我都很乐意听取你的想法
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <Button href="/contact" variant="primary" showArrow>
            了解更多
          </Button>
          <Button href="mailto:renmengkai@gmail.com" variant="secondary">
            发送邮件
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
